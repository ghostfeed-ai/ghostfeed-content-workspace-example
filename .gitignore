.env
.DS_Store
__pycache__/
*.pyc

# Local media assets are intentionally not shipped in this public repo.
PepIntel/Avatars/**
PepIntel/Videos/**
PepIntel/Export/**
PepIntel/yet to be clonned/**

# Research source downloads are local-only and should not be shipped.
research/**/content/**
research/**/slideshows/**
research/**/extractions/**
research/**/analysis/_intermediate/**
research/**/*.json
research/**/*.txt

# Keep only the workspace folder skeleton.
!PepIntel/Avatars/.gitkeep
!PepIntel/Videos/.gitkeep
!PepIntel/Export/.gitkeep
!PepIntel/yet to be clonned/.gitkeep
!research/**/content/.gitkeep
!research/**/slideshows/.gitkeep
